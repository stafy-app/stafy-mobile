{
  "expo": {
    "scheme": "stafyapp",
    "name": "stafy-mobile",
    "slug": "stafy-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/Logo_Stafy.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/Logo_Stafy.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/assets/Logo_Stafy.png",
        "backgroundImage": "./src/assets/Logo_Stafy.png",
        "monochromeImage": "./src/assets/Logo_Stafy.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.stafymobile"
    },
    "web": {
      "favicon": "./src/assets/Logo_Stafy.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d9ecbe78-5e67-4326-a193-faec421660a0"
      }
    }
  }
}
